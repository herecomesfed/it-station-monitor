---
interface Props {
  title: string;
}
const { title } = Astro.props;
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <ClientRouter />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-slate-50 font-['Inter',sans-serif] text-slate-900">
    <nav
      class="bg-white border-b border-slate-200 sticky top-0 z-50 px-4 py-3 shadow-sm"
    >
      <div class="max-w-md mx-auto flex items-center justify-between">
        <span class="font-bold text-xl tracking-tight text-blue-600"
          >RailMonitor</span
        >
        <div
          class="w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center"
        >
          <span class="text-xs font-bold">IT</span>
        </div>
      </div>
    </nav>
    <slot />
  </body>
</html>
