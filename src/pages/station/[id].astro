---
import Layout from "../../layouts/Layout.astro";
import StationBoardApp from "../../components/station/StationBoardApp";

const { id } = Astro.params;
const stationName = Astro.url.searchParams.get("name");

// Redirect to home if station name is missing
if (!stationName) {
  return Astro.redirect("/");
}
---

<Layout title={`${stationName} - ITStationMonitor`} showBackButton={true}>
  <StationBoardApp client:load placeId={id!} stationName={stationName} />
</Layout>
